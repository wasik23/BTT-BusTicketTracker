# Database
# Local dev: SQLite (no installation needed) — just copy this file to .env
DATABASE_URL="file:./dev.db"
# Production (Neon PostgreSQL) — for Vercel deploy, set this in Vercel env vars:
#   DATABASE_URL="postgresql://USER:PASS@HOST.neon.tech/btt?sslmode=require"

# Admin auth — generate a random 32+ character string
JWT_SECRET="change-me-to-a-long-random-string-please-32chars+"

# Encryption key for storing payment gateway credentials (32 chars exactly)
ENCRYPTION_KEY="change-me-32-character-secret-key"

# Initial admin user (created on first db:seed)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMeAfterFirstLogin!"

# GPS ingest endpoint shared secret (so only your trackers can post location)
GPS_INGEST_SECRET="change-me-gps-shared-secret"
